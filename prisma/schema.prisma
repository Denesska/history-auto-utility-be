// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            Int      @id @default(autoincrement())
  google_id     String   @unique
  email         String   @unique
  first_name    String
  last_name     String
  picture       String
  created_at    DateTime @default(now())
  cars          Car[]
  refresh_token String?
}

model Car {
  id                       Int               @id @default(autoincrement())
  vin                      String?           @unique
  make                     String
  model                    String
  variant                  String?
  year                     Int
  license_plate            String
  fuel_type                FuelType?
  transmission             TransmissionType?
  engine                   String?
  color                    String?
  current_mileage          Int
  ownership_start_date     DateTime?
  rca_expiry_date          DateTime?
  itp_expiry_date          DateTime?
  rov_expiry_date          DateTime?
  last_oil_service_date    DateTime?
  last_oil_service_mileage Int?
  user_id                  Int
  user                     User              @relation(fields: [user_id], references: [id])
  maintenanceRecords       MaintenanceRecord[]
  documents                Document[]
  photos                   CarPhoto[]
}

model CarPhoto {
  id         Int     @id @default(autoincrement())
  car_id     Int
  url        String
  is_default Boolean @default(false)
  car        Car     @relation(fields: [car_id], references: [id], onDelete: Cascade)
}

model Document {
  id            Int      @id @default(autoincrement())
  car_id        Int
  document_type String
  issue_date    DateTime
  expiry_date   DateTime
  car           Car      @relation(fields: [car_id], references: [id])
}

model MaintenanceRecord {
  id               Int             @id @default(autoincrement())
  car_id           Int
  service_date     DateTime
  mileage          Int
  description      String
  service_type     ServiceType
  service_category ServiceCategory
  cost             Float
  expiry_date      DateTime
  car              Car             @relation(fields: [car_id], references: [id])
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  PLUGIN_HYBRID
  ELECTRIC
  LPG
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
  SEMI_AUTOMATIC
}

enum ServiceType {
  REPAIR
  MAINTENANCE
  IMPROVEMENT
}

enum ServiceCategory {
  OIL_CHANGE
  BRAKE_SERVICE
  TRANSMISSION_SERVICE
  TIRE_SERVICE
  OTHER
}
